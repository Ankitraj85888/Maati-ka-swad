# =====================================================
# MAATI KA SWAD — Backend Environment Variables
# =====================================================

# Fast2SMS API Key for sending OTP
# Get your key from: https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=YOUR_API_KEY_HERE

# JWT Secret — change this to a long random string in production!
JWT_SECRET=maatikaswad_secret_key_change_this_in_production

# Server Port (Render sets this automatically)
PORT=3001

# PostgreSQL — Render adds DATABASE_URL automatically when you provision a DB
# DATABASE_URL=postgresql://user:password@host:5432/dbname
